{
  "manifest_version": 3,
  "name": "Google Drive Markdown Preview",
  "version": "1.2.0",
  "description": "Automatically renders markdown files in Google Drive preview mode",
  
  "permissions": [
    "activeTab",
    "storage"
  ],
  
  "host_permissions": [
    "https://drive.google.com/*"
  ],
  
  "content_scripts": [
    {
      "matches": ["https://drive.google.com/*"],
      "js": ["lib/marked.min.js", "lib/purify.min.js", "content.js"],
      "css": ["styles/markdown.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "action": {
    "default_popup": "popup.html",
    "default_title": "Google Drive Markdown Preview Settings"
  },
  
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["styles/markdown.css"],
      "matches": ["https://drive.google.com/*"]
    }
  ]
}